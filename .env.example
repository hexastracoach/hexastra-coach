# ─────────────────────────────────────────────────────────────────────────────
# Hexastra Coach — Variables d'environnement
# Copier ce fichier en .env.local et remplir chaque valeur.
# Ne jamais committer .env.local dans le dépôt.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Projet Supabase : https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...  # clé anon (publique)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...      # clé service role (SECRÈTE — server-side only)

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Plateforme OpenAI : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ID du vector store utilisé pour l'enrichissement RAG (scripts utilitaires)
# Laisser vide si inutilisé localement.
OPENAI_VECTOR_STORE_ID=vs_...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Dashboard Stripe : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...             # sk_test_... en développement
# Webhook secret (stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Hexastra API (Railway) ────────────────────────────────────────────────────
# URL de l'API calculs astro/HD/numérologie hébergée sur Railway.
# Par défaut : https://hexastra-api-production.up.railway.app
HEXASTRA_API_URL=https://hexastra-api-production.up.railway.app
HEXASTRA_API_KEY=hx_...                   # Clé d'authentification Railway

# ── OpenCage Geocoding ────────────────────────────────────────────────────────
# API de géocodage pour la recherche de lieux de naissance.
# https://opencagedata.com/dashboard
OPENCAGE_API_KEY=...

# ── Resend (emails) ───────────────────────────────────────────────────────────
# Envoi d'emails transactionnels (formulaire de contact).
# https://resend.com/api-keys
RESEND_API_KEY=re_...
CONTACT_EMAIL_TO=contact@hexastra.coach   # Destinataire des messages de contact
EMAIL_FROM=noreply@hexastra.coach         # Expéditeur (doit être un domaine vérifié Resend)

# ── Application ───────────────────────────────────────────────────────────────
# URL publique de l'application (utilisée pour les redirections Stripe).
# En développement : http://localhost:3000
NEXT_PUBLIC_APP_URL=https://hexastra.coach

# ── n8n (optionnel) ───────────────────────────────────────────────────────────
# Endpoint n8n pour la synchronisation d'état utilisateur.
# Laisser vide pour désactiver.
N8N_STATE_URL=https://n8n.example.com/webhook/hexastra-state

# ── Observabilité (optionnel) ─────────────────────────────────────────────────
# URL du webhook pour la remontée d'erreurs (ex: Slack, Discord, custom endpoint).
# Laisser vide pour désactiver le reporting.
ERROR_REPORTING_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Tests E2E (CI uniquement) ─────────────────────────────────────────────────
# URL de base pour Playwright (non requis en local, défaut : http://localhost:3000)
# PLAYWRIGHT_BASE_URL=http://localhost:3000

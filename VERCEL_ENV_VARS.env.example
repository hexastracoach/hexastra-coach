# ============================================================
# HEXASTRA — Variables à coller dans Vercel
# Vercel > ton projet > Settings > Environment Variables
# ============================================================

# --- SUPABASE ---
# supabase.com > ton projet > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# --- STRIPE ---
# dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_live_AREMPLACER

# dashboard.stripe.com > Developers > Webhooks
# → Créer un webhook vers : https://ton-site.vercel.app/api/stripe/webhook
# → Événement à écouter : checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_AREMPLACER

# dashboard.stripe.com > Products > ton produit > Price ID
STRIPE_PRICE_PREMIUM=price_AREMPLACER

# --- N8N ---
N8N_WEBHOOK_CHAT_URL=https://ton-instance.n8n.cloud/webhook/hexastra-chat
N8N_WEBHOOK_BIRTH_URL=https://ton-instance.n8n.cloud/webhook/hexastra-birth
N8N_WEBHOOK_PREMIUM_URL=https://ton-instance.n8n.cloud/webhook/hexastra-premium
# Mot de passe secret (min 32 caractères, à inventer)
N8N_WEBHOOK_SECRET=change_moi_avec_un_secret_tres_long_ici_123456
# Timeout max appel chat n8n. 120000ms = 2 minutes.
N8N_WEBHOOK_TIMEOUT_MS=120000

# --- APP ---
# Mettre l'URL finale de ton déploiement Vercel
NEXT_PUBLIC_BASE_URL=https://ton-site.vercel.app
